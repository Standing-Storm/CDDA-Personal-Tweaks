[
  {
    "type": "MOD_INFO",
    "id": "sleepscumming_soulslike_version",
    "name": "<color_green>Sleepscumming</color>: the <color_red>Soulslike penalty</color> version",
    "authors": [ "Standing-Storm" ],
    "description": "When you die, you go back to the last place you slept.  Your stuff does not come with you.  You also suffer a penalty on damage and to your HP until you return to the place you died.",
    "category": "misc_additions",
    "dependencies": [ "dda" ],
    "conflicts": [ "sleepscumming_keep_your_stuff", "sleepscumming_lose_your_stuff" ]
  },
  {
    "type": "effect_on_condition",
    "id": "EOC_SLEEPSCUMMING_SAVE_LOCATION",
    "eoc_type": "EVENT",
    "required_event": "character_falls_asleep",
    "effect": { "u_location_variable": { "u_val": "sleepscumming_location_variable" }, "min_radius": 0, "max_radius": 0 }
  },
  {
    "type": "effect_on_condition",
    "id": "EOC_SLEEPSCUMMING_RETURN",
    "eoc_type": "PREVENT_DEATH",
    "condition": { "math": [ "has_var(u_sleepscumming_location_variable)" ] },
    "effect": [
      "u_prevent_death",
      { "u_message": "Reality warps and you are somewhere else.", "popup": true },
      { "run_eocs": "EOC_SLEEPSCUMMING_RETURN_START" }
    ]
  },
  {
    "type": "effect_on_condition",
    "id": "EOC_SLEEPSCUMMING_RETURN_START",
    "effect": [
      { "u_add_effect": "incorporeal", "duration": 1 },
      { "u_add_effect": "downed", "duration": 1 },
      { "run_eocs": "EOC_SLEEPSCUMMING_RETURN_HEAL" },
      { "u_cast_spell": { "id": "sleepscumming_terrain_transform_spell", "hit_self": true } },
      { "run_eocs": "EOC_SLEEPSCUMMING_RETURN_FINALIZE", "time_in_future": "1 seconds" }
    ]
  },
  {
    "type": "effect_on_condition",
    "id": "EOC_SLEEPSCUMMING_RETURN_HEAL",
    "effect": [
      { "math": [ "u_hp('ALL') = 999" ] },
      { "math": [ "u_hp('ALL_MAJOR') = 45" ] },
      { "math": [ "u_val('thirst') = 0" ] },
      { "math": [ "u_vitamin('redcells') = 0" ] },
      { "math": [ "u_vitamin('bad_food') = 0" ] },
      { "math": [ "u_vitamin('blood') = 0" ] },
      { "math": [ "u_vitamin('instability') = 0" ] },
      { "math": [ "u_pain() = 0" ] },
      { "math": [ "u_val('rad') = 0" ] },
      { "u_lose_effect": "corroding" },
      { "u_lose_effect": "onfire" },
      { "u_lose_effect": "dazed" },
      { "u_lose_effect": "stunned" },
      { "u_lose_effect": "venom_blind" },
      { "u_lose_effect": "formication" },
      { "u_lose_effect": "blisters" },
      { "u_lose_effect": "frostbite" },
      { "u_lose_effect": "frostbite_recovery" },
      { "u_lose_effect": "wet" },
      { "u_lose_effect": "slimed" },
      { "u_lose_effect": "migo_atmosphere" },
      { "u_lose_effect": "fetid_goop" },
      { "u_lose_effect": "sap" },
      { "u_lose_effect": "nausea" },
      { "u_lose_effect": "bleed" },
      { "u_add_effect": "effect_sleepscumming_soulslike_penalty", "duration": "PERMANENT" }
    ]
  },
  {
    "type": "effect_on_condition",
    "id": "EOC_SLEEPSCUMMING_RETURN_FINALIZE",
    "effect": [
      { "u_teleport": { "u_val": "sleepscumming_location_variable" } },
      { "math": [ "u_pain() = 0" ] },
      {
        "foreach": "ids",
        "var": { "context_val": "id" },
        "target": "vitamin",
        "effect": [ { "math": [ "u_vitamin(_id) = 0" ] } ]
      }
    ]
  },
  {
    "id": "sleepscumming_gravestone_creation",
    "type": "SPELL",
    "name": "Make Grave",
    "description": "Makes a grave.  Spooky!",
    "valid_targets": [ "ground", "self" ],
    "effect": "ter_transform",
    "effect_str": "ter_sleepscumming_grave_creating",
    "shape": "blast",
    "max_level": 20,
    "difficulty": 4,
    "flags": [ "NO_LEGS", "NO_HANDS", "NO_PROJECTILE" ]
  },
  {
    "type": "ter_furn_transform",
    "id": "ter_sleepscumming_grave_creating",
    "furniture": [ { "result": "f_sleepscumming_grave_stone", "message": "" } ]
  },
  {
    "type": "effect_type",
    "id": "effect_sleepscumming_soulslike_penalty",
    "name": [ "Split Soul" ],
    "desc": [
      "You avoided death, but at what cost?  Your combat prowess and resilience are penalized until you return to the site of your death."
    ],
    "rating": "bad",
    "enchantments": [
      {
        "melee_damage_bonus": [
          { "type": "bash", "multiply": -0.15 },
          { "type": "cut", "multiply": -0.15 },
          { "type": "heat", "multiply": -0.15 },
          { "type": "acid", "multiply": -0.15 },
          { "type": "stab", "multiply": -0.15 },
          { "type": "biological", "multiply": -0.15 }
        ]
      },
      { "values": [ { "value": "RANGED_DAMAGE", "multiply": -0.15 }, { "value": "MAX_HP", "multiply": -0.15 } ] }
    ]
  },
  {
    "type": "furniture",
    "id": "f_sleepscumming_grave_stone",
    "looks_like": "f_grave_stone",
    "name": "death location",
    "description": "An ebony-black slab wavers in and out of your vision here, alternately visible and not.",
    "symbol": "^",
    "color": "light_gray",
    "move_cost_mod": 2,
    "coverage": 50,
    "required_str": -1,
    "flags": [ "MINEABLE", "TRANSPARENT", "MOUNTABLE", "ROUGH", "PLACE_ITEM" ],
    "examine_action": { "type": "effect_on_condition", "effect_on_conditions": [ "EOC_SLEEPSCUMMING_PENALTY_REMOVE" ] },
    "bash": {
      "str_min": 10000,
      "str_max": 160000,
      "sound": "crash!",
      "sound_fail": "thump!",
      "items": [ { "item": "rock", "count": [ 8, 14 ] } ]
    }
  },
  {
    "type": "effect_on_condition",
    "id": "EOC_SLEEPSCUMMING_PENALTY_REMOVE",
    "effect": [
      { "u_lose_effect": "effect_sleepscumming_soulslike_penalty" },
      {
        "u_message": "You take in a shuddering breath as the metaphorical emptiness within you fades.  You are whole once again.",
        "type": "good"
      }
    ]
  }
]
